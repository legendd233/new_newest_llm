<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_background">

    <!-- Sleek Header -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_background"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/profile_title"
            app:titleTextColor="@color/text_primary"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleMedium">

            <TextView
                android:id="@+id/btn_lang"
                style="@style/AppText.OverlineAccent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="16dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="EN"
                android:background="@drawable/bg_source_tag"
                android:backgroundTint="@color/ai_glow"
                android:clickable="true"
                android:focusable="true" />
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- User Info Section -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_user"
        style="@style/AppCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/app_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:paddingVertical="40dp">

            <TextView
                android:id="@+id/tv_username"
                style="@style/AppText.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                style="@style/AppText.Overline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="VERIFIED LAB IDENTITY" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Actions Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cv_user">

        <TextView
            android:id="@+id/btn_change_password"
            style="@style/AppText.Subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/change_password"
            android:gravity="center"
            android:padding="20dp"
            android:background="@drawable/bg_action_outlined"
            android:clickable="true"
            android:focusable="true" />

        <View android:layout_width="0dp" android:layout_height="16dp" />

        <TextView
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/logout"
            android:gravity="center"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:padding="20dp"
            android:background="@drawable/bg_action_filled"
            android:backgroundTint="@color/heart_red"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Sleek Bottom Nav -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/bg_card"
        android:elevation="16dp"
        android:paddingBottom="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nav_home"
            android:gravity="center"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            app:drawableTopCompat="@drawable/ic_nav_home"
            android:drawablePadding="6dp"
            app:drawableTint="@color/text_muted" />

        <TextView
            android:id="@+id/nav_favorites"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nav_favorites"
            android:gravity="center"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            app:drawableTopCompat="@drawable/ic_nav_fav"
            android:drawablePadding="6dp"
            app:drawableTint="@color/text_muted" />

        <TextView
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nav_me"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/accent_blue"
            app:drawableTopCompat="@drawable/ic_nav_profile"
            android:drawablePadding="6dp"
            app:drawableTint="@color/accent_blue" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
