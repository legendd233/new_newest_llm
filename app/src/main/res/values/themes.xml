<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.New_newest_llm" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/bg_card</item>
        <item name="android:windowBackground">@color/bg_background</item>
    </style>

    <style name="Theme.New_newest_llm" parent="Base.Theme.New_newest_llm" />

    <!-- Custom Style for Premium Toasts/Labels -->
    <style name="PremiumToast">
        <item name="android:background">@drawable/bg_source_tag</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>